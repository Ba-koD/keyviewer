#!/bin/sh
set -eu

NULL_SHA="0000000000000000000000000000000000000000"

if command -v cargo >/dev/null 2>&1; then
  CARGO_BIN="$(command -v cargo)"
elif [ -n "${USERPROFILE:-}" ] && [ -x "${USERPROFILE}/.cargo/bin/cargo.exe" ]; then
  CARGO_BIN="${USERPROFILE}/.cargo/bin/cargo.exe"
elif [ -n "${HOME:-}" ] && [ -x "${HOME}/.cargo/bin/cargo.exe" ]; then
  CARGO_BIN="${HOME}/.cargo/bin/cargo.exe"
elif [ -n "${HOME:-}" ] && [ -x "${HOME}/.cargo/bin/cargo" ]; then
  CARGO_BIN="${HOME}/.cargo/bin/cargo"
else
  echo "pre-push: cargo executable not found." >&2
  exit 1
fi

run_check() {
  label="$1"
  shift
  echo "$label"
  worktree_dir="$1"
  shift
  (
    cd "$worktree_dir"
    "$CARGO_BIN" "$@"
  )
}

run_checks_for_commit() {
  commit_sha="$1"
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/keyviewer-pre-push.XXXXXX")"

  cleanup() {
    rm -rf "$tmpdir"
  }

  git archive "$commit_sha" | tar -x -C "$tmpdir"

  status=0
  (
    run_check "[pre-push 1/3] cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check" \
      "$tmpdir" \
      fmt --manifest-path src-tauri/Cargo.toml --all -- --check

    run_check "[pre-push 2/3] cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings" \
      "$tmpdir" \
      clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings

    run_check "[pre-push 3/3] cargo test --manifest-path src-tauri/Cargo.toml --all-targets --all-features" \
      "$tmpdir" \
      test --manifest-path src-tauri/Cargo.toml --all-targets --all-features
  ) || status=$?

  cleanup
  return "$status"
}

has_updates=0
checked_shas=""
while read -r local_ref local_sha remote_ref remote_sha
do
  if [ -z "${local_sha:-}" ] || [ "${local_sha}" = "${NULL_SHA}" ]; then
    continue
  fi

  if [ "${local_sha}" = "${remote_sha}" ]; then
    continue
  fi

  commit_sha="$(git rev-parse "${local_sha}^{commit}")"

  already_checked=0
  for checked_sha in ${checked_shas}
  do
    if [ "${checked_sha}" = "${commit_sha}" ]; then
      already_checked=1
      break
    fi
  done

  if [ "${already_checked}" -eq 1 ]; then
    continue
  fi

  has_updates=1
  checked_shas="${checked_shas} ${commit_sha}"
  echo "pre-push: validating ${local_ref} at ${commit_sha}"
  run_checks_for_commit "${commit_sha}"
done

if [ "${has_updates}" -eq 0 ]; then
  echo "pre-push: nothing to push, skipping checks."
  exit 0
fi

echo "pre-push checks passed."
